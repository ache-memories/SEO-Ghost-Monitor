<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>SEO Ghost Monitor</title>
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #0a0a0a; color: white; }
        input { padding: 10px; width: 300px; border-radius: 5px; border: none; }
        button { padding: 10px 20px; margin-top: 10px; background: #0070f3; color: white; border: none; border-radius: 5px; cursor: pointer; }
        #result { margin-top: 20px; padding: 20px; background: #1a1a1a; border-radius: 10px; display: none; }
    </style>
</head>
<body>
    <h1>👻 SEO Ghost Monitor</h1>
    <p>أدخل رابط الموقع لمراقبته:</p>
    <input type="text" id="siteUrl" placeholder="https://example.com">
    <button onclick="checkSite()">فحص الآن</button>
    <div id="result"></div>

    <script>
        async function checkSite() {
            const url = document.getElementById('siteUrl').value;
            const resDiv = document.getElementById('result');
            resDiv.style.display = 'block';
            resDiv.innerHTML = 'جاري الفحص...';
            
            try {
                const response = await fetch(`/api/monitor?url=${url}`);
                const data = await response.json();
                resDiv.innerHTML = `<pre>${JSON.stringify(data, null, 2)}</pre>`;
            } catch (e) {
                resDiv.innerHTML = 'حدث خطأ في الاتصال.';
            }
        }
    </script>
</body>
</html>
