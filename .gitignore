const axios = require('axios');
const crypto = require('crypto');

module.exports = async (req, res) => {
  // Extract URL from query parameters
  const { url } = req.query;

  // Validate URL presence
  if (!url) {
    return res.status(400).json({ 
      error: "Bad Request", 
      message: "Please provide a target URL in the query string (?url=...)" 
    });
  }

  try {
    // Fetch website content with a professional User-Agent to avoid blocks
    const response = await axios.get(url, {
      headers: {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
        'Cache-Control': 'no-cache'
      },
      timeout: 10000 // 10 seconds timeout to prevent serverless function hang
    });

    const htmlContent = response.data;

    // Generate a unique MD5 hash (fingerprint) of the HTML content
    const hash = crypto.createHash('md5').update(String(htmlContent)).digest('hex');

    // Return successful response in English
    res.status(200).json({
      status: "success",
      url: url,
      current_hash: hash,
      timestamp: new Date().toISOString(),
      message: "Ghost analysis completed."
    });

  } catch (error) {
    // Handle errors and crashes gracefully
    res.status(500).json({ 
      status: "error",
      error: "Fetch Failed",
      details: error.message,
      note: "The target website might be blocking automated requests or is currently offline."
    });
  }
};
